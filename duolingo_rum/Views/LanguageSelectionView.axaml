<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:duolingo_rum.ViewModels"
             xmlns:conv="using:duolingo_rum.Converters"
             x:Class="duolingo_rum.Views.LanguageSelectionView"
             x:DataType="vm:LanguageSelectionViewModel">

    <UserControl.Resources>
        <conv:BoolToDifficultyConverter x:Key="DifficultyConverter"/>
    </UserControl.Resources>

    <ScrollViewer>
        <StackPanel Margin="20" Spacing="15" HorizontalAlignment="Center" Width="350">
            
            <TextBlock Text="🌍 Настройки языка" FontSize="24" FontWeight="Bold"
                       HorizontalAlignment="Center" Margin="0,20,0,10"/>
            
            <TextBlock Text="Какой язык хочешь выучить?" FontSize="14"
                       Foreground="#666" HorizontalAlignment="Center"/>
            
            <ComboBox ItemsSource="{Binding Languages}"
                      SelectedItem="{Binding SelectedTargetLanguage}"
                      DisplayMemberBinding="{Binding Name}"
                      IsEnabled="{Binding !IsLoading}"
                      Width="250"
                      HorizontalAlignment="Center"
                      Margin="0,10,0,0"/>
            
            <TextBlock Text="Твой родной язык:" FontSize="14"
                       Foreground="#666" HorizontalAlignment="Center" Margin="0,15,0,0"/>
            
            <ComboBox ItemsSource="{Binding Languages}"
                      SelectedItem="{Binding SelectedNativeLanguage}"
                      DisplayMemberBinding="{Binding Name}"
                      IsEnabled="{Binding !IsLoading}"
                      Width="250"
                      HorizontalAlignment="Center"
                      Margin="0,10,0,0"/>
            
            <TextBlock Text="Уровень сложности:" FontSize="14"
                       Foreground="#666" HorizontalAlignment="Center" Margin="0,20,0,10"/>
            
            <!-- Beginner -->
            <Border Background="#E8F5E9" CornerRadius="8" Padding="12" Margin="0,5">
                <RadioButton GroupName="Difficulty" 
                             IsChecked="{Binding SelectedDifficulty, Mode=TwoWay, Converter={StaticResource DifficultyConverter}, ConverterParameter='beginner'}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="🌱" FontSize="16"/>
                        <TextBlock Text="Начинающий (Beginner)" FontSize="14"/>
                    </StackPanel>
                </RadioButton>
            </Border>
            
            <!-- Intermediate -->
            <Border Background="#FFF3E0" CornerRadius="8" Padding="12" Margin="0,5">
                <RadioButton GroupName="Difficulty"
                             IsChecked="{Binding SelectedDifficulty, Mode=TwoWay, Converter={StaticResource DifficultyConverter}, ConverterParameter='intermediate'}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="📚" FontSize="16"/>
                        <TextBlock Text="Средний (Intermediate)" FontSize="14"/>
                    </StackPanel>
                </RadioButton>
            </Border>
            
            <!-- Advanced -->
            <Border Background="#FCE4EC" CornerRadius="8" Padding="12" Margin="0,5">
                <RadioButton GroupName="Difficulty"
                             IsChecked="{Binding SelectedDifficulty, Mode=TwoWay, Converter={StaticResource DifficultyConverter}, ConverterParameter='advanced'}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="🚀" FontSize="16"/>
                        <TextBlock Text="Продвинутый (Advanced)" FontSize="14"/>
                    </StackPanel>
                </RadioButton>
            </Border>
            
            <Button Command="{Binding RegisterCommand}"
                    HorizontalAlignment="Stretch"
                    Background="#4CAF50"
                    Foreground="White"
                    Height="50"
                    CornerRadius="10"
                    FontSize="16"
                    FontWeight="Bold"
                    IsEnabled="{Binding !IsLoading}"
                    Margin="0,20,0,0">
                <TextBlock Text="🚀 Начать обучение" HorizontalAlignment="Center"/>
            </Button>
            
            <Button Command="{Binding BackCommand}"
                    HorizontalAlignment="Stretch"
                    Background="Transparent"
                    Foreground="#888"
                    Height="40"
                    Margin="0,5,0,0">
                <TextBlock Text="← Назад" HorizontalAlignment="Center"/>
            </Button>
            
            <TextBlock Text="{Binding Status}" 
                       Foreground="Red"
                       HorizontalAlignment="Center" 
                       TextWrapping="Wrap"
                       Margin="0,10,0,0"/>
            
            <TextBlock Text="⏳ Загрузка языков..." 
                       IsVisible="{Binding IsLoading}"
                       HorizontalAlignment="Center" 
                       Foreground="Gray"
                       Margin="0,10,0,0"/>
            
        </StackPanel>
    </ScrollViewer>
</UserControl>